{
  "name": "jobgrinder",
  "version": "0.1.0",
  "private": true,
  "description": "Local Mac-first job triage tool for Airtable exports and Ollama scoring.",
  "type": "module",
  "bin": {
    "jobgrinder": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
